# =============================================================================
# Email Template Management Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# =============================================================================

# --- Supabase (Required) ---
# Find these in your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Resend (Required for sending test emails) ---
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# The "from" email address for sent emails. Must be a verified domain in Resend.
RESEND_FROM=onboarding@your-domain.com

# --- OpenRouter (Required for AI assistant features) ---
# Sign up at https://openrouter.ai/keys and create a free API key.
# Uses meta-llama/llama-3.3-70b-instruct:free model at zero cost.
OPENROUTER_API_KEY=your-openrouter-api-key

# =============================================================================
# Optional: Override the default rate limits
# =============================================================================
# RATE_LIMIT_MAX_PER_MINUTE=10
